# Copy to .env and fill in. VITE_* values are embedded at BUILD time (pass as --build-arg to docker build).
# Non-VITE values are read at RUNTIME by server functions.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server listen config (defaults shown)
HOST=0.0.0.0
PORT=8080
